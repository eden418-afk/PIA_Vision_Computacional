def main():
    specs = get_piece_specs()

    csv_path = os.path.join(RESULTADOS_DIR, "cad_ground_truth.csv")
    json_path = os.path.join(RESULTADOS_DIR, "cad_geometry.json")

    rows = []

    for index, spec in enumerate(specs, start=1):
        row = save_piece(spec, index)
        rows.append(row)
        print(f"Generada pieza CAD {index:02d}: {row['modelo_cad']}")

    with open(csv_path, "w", newline="", encoding="utf-8") as csv_file:
        fieldnames = [
            "imagen",
            "modelo_cad",
            "figura",
            "categoria_geometrica",
            "num_agujeros_cad",
            "angulo_cad_grados",
            "centroide_cad_mm_x",
            "centroide_cad_mm_y",
            "centroide_cad_mm_z",
            "tx_mm",
            "ty_mm",
        ]

        writer = csv.DictWriter(csv_file, fieldnames=fieldnames)
        writer.writeheader()

        for row in rows:
            writer.writerow(row)

    with open(json_path, "w", encoding="utf-8") as json_file:
        json.dump(specs, json_file, indent=4)

    print("")
    print("Proceso terminado.")
    print(f"Modelos CAD guardados en: {CAD_DIR}")
    print(f"Referencia CAD guardada en: {csv_path}")
    print(f"Geometría CAD guardada en: {json_path}")


main()